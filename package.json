{
  "name": "scrum-bot",
  "version": "1.0.0",
  "description": "Discord bot that posts scrum templates via slash commands + modals",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "deploy-commands": "tsx src/deploy-commands.ts",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "discord.js": "14.26.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}